# Anthropic API key — get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model
# ANTHROPIC_MODEL=claude-haiku-4-5

# Railway sets PORT automatically; locally defaults to 3000
# PORT=3000

# ─── Analytics (optional but recommended) ───────────────────────────────
# Server-side event logger writes to Supabase if these are set. Both are
# required together; if either is missing, events still go to events.log on disk.
#
# Get the project URL and service role key from your Supabase dashboard:
#   Settings → API → Project URL          (SUPABASE_URL)
#   Settings → API → service_role (secret) (SUPABASE_SERVICE_ROLE_KEY)
#
# DO NOT expose the service_role key to the browser. Server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
