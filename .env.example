# Anthropic API key — get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model
# ANTHROPIC_MODEL=claude-haiku-4-5

# Railway sets PORT automatically; locally defaults to 3000
# PORT=3000

# ─── Analytics (optional but recommended) ───────────────────────────────
# Server-side event logger writes to Supabase if these are set. Both are
# required together; if either is missing, events still go to events.log on disk.
#
# Get the project URL and service role key from your Supabase dashboard:
#   Settings → API → Project URL          (SUPABASE_URL)
#   Settings → API → service_role (secret) (SUPABASE_SERVICE_ROLE_KEY)
#
# DO NOT expose the service_role key to the browser. Server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Live counselor handoff via YakChat SMS (feature-flagged) ───────────
# DO NOT flip YAKCHAT_HANDOFF_ENABLED=true until:
#   1. The consent text in consent.js has been reviewed by Keiser legal counsel
#   2. YakChat number is provisioned and STOP-webhook is configured
#   3. Counselor coverage policy is defined (which hours have live response)
#
# Until all three are true, leave this variable unset — the consent modal is
# hidden in the UI and the SMS code path is short-circuited server-side.
YAKCHAT_HANDOFF_ENABLED=false

# YakChat API credentials. Server-side only. Confirm exact API shape against
# current YakChat docs before going live — the placeholder in handoff.js may
# need to change.
YAKCHAT_API_KEY=
YAKCHAT_FROM_NUMBER=
# Optional override; defaults to https://api.yakchat.com
# YAKCHAT_API_BASE=

# Optional: Microsoft Teams Incoming Webhook URL. When set, every recorded
# consent (i.e. every new lead from Skylar) is posted as a card into the Teams
# channel so counselors see it immediately. Works independently of YakChat —
# you can use Teams notifications even when SMS is off.
TEAMS_WEBHOOK_URL=
